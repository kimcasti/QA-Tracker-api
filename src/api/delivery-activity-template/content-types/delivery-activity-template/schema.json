{
  "kind": "collectionType",
  "collectionName": "delivery_activity_templates",
  "info": {
    "singularName": "delivery-activity-template",
    "pluralName": "delivery-activity-templates",
    "displayName": "Delivery Activity Template"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Gestión y Gobernanza del Proyecto",
        "Discovery y Evaluación Inicial",
        "Administración de Infraestructura y Entornos",
        "Mantenimiento y Soporte Técnico",
        "Desarrollo y Evolución del Software",
        "Gestión de Calidad y Control de Pruebas",
        "Gestión de Seguridad y Cumplimiento",
        "Gestión de DevOps y Configuración Técnica",
        "Monitoreo, Optimización y Rendimiento",
        "Documentación e Informes"
      ],
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "required": true
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "required": true
    },
    "deliveryUnits": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::delivery-unit.delivery-unit",
      "mappedBy": "activities"
    }
  }
}
